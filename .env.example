# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` file — it is already excluded in .gitignore.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/kamransteelworks

# --- JWT (our own login tokens, issued after Google verifies you) ---
JWT_SECRET_KEY=changeme-generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI features (used by future endpoints) ---
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# --- Cloudinary (image hosting, used by future endpoints) ---
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- Mailtrap (email sending/testing, used by future endpoints) ---
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=your-mailtrap-username
MAILTRAP_PASSWORD=your-mailtrap-password

# --- Google OAuth (admin login) ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- The ONLY emails allowed to log in as admin (comma-separated) ---
ADMIN_GMAIL_ADDRESSES=youradmin1@gmail.com,youradmin2@gmail.com

# --- Frontend origins allowed to call this API (comma-separated) ---
CORS_ORIGINS=http://localhost:3000
